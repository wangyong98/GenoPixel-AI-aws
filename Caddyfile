{
    auto_https off
    admin off
}

:80 {
    encode gzip zstd
    # Serve generated artifacts under /assets from the workspace 'out/' directory
    handle_path /assets/* {
        root * /data/out
        file_server
    }
    handle_path /apps/genopixel-datasets* {
        root * /data/web/genopixel-datasets
        try_files {path} /index.html
        file_server
    }
    handle /api/genopixel-catalog/* {
        reverse_proxy genopixel_tool_server:18889
    }
    handle /api/genopixel-runtime/* {
        reverse_proxy genopixel_tool_server:18889
    }
    reverse_proxy {$UPSTREAM:http://openwebui:8080}
}
